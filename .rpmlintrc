# rpmlint configuration for the ros2-rpm COPR.
#
# We intentionally install to /opt/ros/<distro> per upstream ROS 2 convention
# (see ADR 0007). Fedora's main-repo policy forbids /opt; rpmlint flags every
# file under /opt/ros/* with `dir-or-file-in-opt`. Suppress that one error
# class — but no others — so genuine packaging mistakes still surface.

addFilter(r"^.*: E: dir-or-file-in-opt /opt/ros/")

# ament_index sentinel files are deliberately zero-length — their presence
# under /opt/ros/<distro>/share/ament_index/resource_index/packages/<pkg>
# signals that the named package is installed. Suppress the rpmlint warning.
addFilter(r"^.*: E: zero-length /opt/ros/[^/]+/share/ament_index/")

# Several ament_cmake support scripts under /opt/ros/<distro>/share/ament_cmake_*/
# carry a python shebang but are invoked via `execute_process(/usr/bin/python3 ...)`
# from CMake. They don't need executable bits and rpmlint flags this as an error.
addFilter(r"^.*: E: non-executable-script /opt/ros/.*\.py 644 /usr/bin/env python3$")

# ament_cmake's CMakeLists copies environment hook files into both share/<pkg>/
# and share/<pkg>/cmake/environment_hooks/ — by upstream design, not a packaging
# bug. Suppress the duplicate-file warning for this specific layout.
addFilter(r"^.*: W: files-duplicate /opt/ros/.*/share/.*/environment/.*\.sh /opt/ros/.*/share/.*/cmake/environment_hooks/environment/.*\.sh$")

# ROS-specific spelling: msg, srv, idl, rmw, fastrtps etc. are technical terms
# in the ROS ecosystem that rpmlint flags as misspellings.
addFilter(r"^.*: E: spelling-error \('(msg|srv|idl|rmw|colcon|rclcpp|rclpy|rosidl|fastrtps|fastdds|rosbag|builtin|cmake|ament|geometry|sensor|nav|tf2|noetic|kilted|jazzy|lyrical)',")

# rosdistro's rosdep maps system "build helper" keys (python3, gtest, gmock,
# eigen, etc.) to their *-devel Fedora packages on the assumption that ROS
# consumers need headers at build time. RPM's `Requires:` doesn't distinguish
# build-time vs runtime, so consumers see *-devel as runtime deps and rpmlint
# complains. The upstream mapping is correct for ROS's build graph; suppress
# the rpmlint warning rather than diverge from upstream.
addFilter(r"^.*: E: devel-dependency .*-devel")

# When linting specs alone (no built RPMs), the file-level filters above don't
# match anything and rpmlint treats them as "unused" errors. The filters are
# load-bearing when linting built RPMs, so keep them at full effect; lower the
# badness of the unused-filter complaint to zero so it doesn't fail CI.
setBadness("unused-rpmlintrc-filter", 0)

