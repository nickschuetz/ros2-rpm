# rpmlint configuration for the ros2-rpm COPR.
#
# We intentionally install to /opt/ros/<distro> per upstream ROS 2 convention
# (see ADR 0007). Fedora's main-repo policy forbids /opt; rpmlint flags every
# file under /opt/ros/* with `dir-or-file-in-opt`. Suppress that one error
# class — but no others — so genuine packaging mistakes still surface.

addFilter(r"^.*: E: dir-or-file-in-opt /opt/ros/")

# ament_index sentinel files are deliberately zero-length — their presence
# under /opt/ros/<distro>/share/ament_index/resource_index/packages/<pkg>
# signals that the named package is installed. Suppress the rpmlint warning.
addFilter(r"^.*: E: zero-length /opt/ros/[^/]+/share/ament_index/")

# When linting specs alone (no built RPMs), the file-level filters above don't
# match anything and rpmlint treats them as "unused" errors. The filters are
# load-bearing when linting built RPMs, so keep them at full effect; lower the
# badness of the unused-filter complaint to zero so it doesn't fail CI.
setBadness("unused-rpmlintrc-filter", 0)

